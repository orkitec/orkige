# clangd configuration: point the language server at the macOS debug build's
# compilation database (CMAKE_EXPORT_COMPILE_COMMANDS is ON in the root
# CMakeLists). Without this, clangd guesses flags and floods the IDE with
# false "file not found" / "unknown type" diagnostics for every engine header.
#
# Note: brand-new source files show stale diagnostics until the next CMake
# configure regenerates the database (clangd falls back to a sibling file's
# flags, which usually suffices).
CompileFlags:
  CompilationDatabase: build/macos-debug

---
# Next-flavor sources live only in the macos-debug-next build - serve them
# from that flavor's database (otherwise clangd applies classic flags and
# floods false errors: the flavor guard #error, missing OGRE-Next headers).
If:
  PathMatch: [.*engine_render_next/.*, .*tests/render_facade/bootstrap_next.*]
CompileFlags:
  CompilationDatabase: build/macos-debug-next
