{
  "name": "orkige",
  "version-string": "2.0.0-dev",
  "description": "Orkige - the orkitec game engine",
  "dependencies": [
    "tinyxml2",
    {
      "name": "ogre",
      "default-features": false,
      "features": [
        "assimp",
        "overlay",
        "zip",
        {
          "name": "freeimage",
          "platform": "!ios & !android"
        },
        {
          "name": "metal",
          "platform": "osx | ios"
        },
        {
          "name": "vulkan",
          "platform": "osx"
        }
      ]
    },
    "sdl3",
    "openal-soft",
    "stb",
    "nanosvg",
    "earcut-hpp",
    "lua",
    "sol2",
    "joltphysics",
    {
      "name": "imgui",
      "features": [
        "docking-experimental"
      ],
      "platform": "!ios & !android"
    },
    {
      "name": "imguizmo",
      "platform": "!ios & !android"
    },
    {
      "name": "catch2",
      "platform": "!ios & !android"
    }
  ],
  "features": {
    "render-next": {
      "description": "Ogre-Next render backend (ORKIGE_RENDER_BACKEND=next - the DEFAULT backend; the default presets macos-debug/macos-release list this feature). Optional so classic-flavor trees (macos-*-classic, ios/android) never build ogre-next; classic ogre stays a base dependency, so a render-next tree carries BOTH backends installed side by side (they are file-disjoint - see ports/ogre-next).",
      "dependencies": [
        "ogre-next"
      ]
    }
  }
}
