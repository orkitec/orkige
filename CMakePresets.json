{
  "version": 8,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "environment": {
        "VCPKG_ROOT": "$penv{HOME}/Development/vcpkg",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/triplets",
        "VCPKG_OVERLAY_PORTS": "${sourceDir}/ports"
      },
      "cacheVariables": {
        "CMAKE_OSX_SYSROOT": "macosx",
        "CMAKE_IGNORE_PREFIX_PATH": "/usr/local"
      }
    },
    {
      "name": "macos-debug",
      "displayName": "macOS Debug",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "macos-release",
      "displayName": "macOS Release",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "macos-debug-next",
      "displayName": "macOS Debug (Ogre-Next render backend)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ORKIGE_RENDER_BACKEND": "next",
        "ORKIGE_BUILD_ENGINE": "ON",
        "ORKIGE_BUILD_TOOLS": "ON",
        "ORKIGE_BUILD_TESTS": "ON",
        "VCPKG_MANIFEST_FEATURES": "render-next"
      }
    },
    {
      "name": "ios-simulator-debug",
      "displayName": "iOS Simulator Debug (arm64)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_OSX_SYSROOT": "iphonesimulator",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "14.0",
        "VCPKG_TARGET_TRIPLET": "arm64-ios-simulator",
        "ORKIGE_BUILD_ENGINE": "ON",
        "ORKIGE_BUILD_TOOLS": "ON",
        "ORKIGE_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "android-debug",
      "displayName": "Android Debug (arm64-v8a, API 28+)",
      "inherits": "base",
      "environment": {
        "ANDROID_NDK_HOME": "$penv{HOME}/Library/Android/sdk/ndk/27.2.12479018"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_OSX_SYSROOT": null,
        "VCPKG_TARGET_TRIPLET": "arm64-android",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "$env{ANDROID_NDK_HOME}/build/cmake/android.toolchain.cmake",
        "ANDROID_ABI": "arm64-v8a",
        "ANDROID_PLATFORM": "android-28",
        "ORKIGE_BUILD_ENGINE": "ON",
        "ORKIGE_BUILD_TOOLS": "ON",
        "ORKIGE_BUILD_TESTS": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "macos-debug",
      "configurePreset": "macos-debug"
    },
    {
      "name": "macos-release",
      "configurePreset": "macos-release"
    },
    {
      "name": "macos-debug-next",
      "configurePreset": "macos-debug-next"
    },
    {
      "name": "ios-simulator-debug",
      "configurePreset": "ios-simulator-debug"
    },
    {
      "name": "android-debug",
      "configurePreset": "android-debug"
    }
  ],
  "testPresets": [
    {
      "name": "unit",
      "displayName": "Unit tests (headless, fast)",
      "configurePreset": "macos-debug",
      "filter": {
        "include": {
          "label": "unit"
        }
      },
      "execution": {
        "jobs": 10
      },
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "desktop",
      "displayName": "Unit + desktop integration (no simulator/emulator boots)",
      "configurePreset": "macos-debug",
      "filter": {
        "exclude": {
          "label": "device"
        }
      },
      "execution": {
        "jobs": 6
      },
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "desktop-next",
      "displayName": "Next-flavor suite (unit + conformance selfcheck/smoke + hello demos + player runs incl. the roller/jumper-lua game selfchecks, B3)",
      "configurePreset": "macos-debug-next",
      "filter": {
        "exclude": {
          "label": "device"
        }
      },
      "execution": {
        "jobs": 6
      },
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "all",
      "displayName": "Full suite (unit + integration incl. device tests)",
      "configurePreset": "macos-debug",
      "execution": {
        "jobs": 6
      },
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
