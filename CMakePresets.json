{
  "version": 8,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "environment": {
        "VCPKG_ROOT": "$penv{HOME}/Development/vcpkg",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/triplets",
        "VCPKG_OVERLAY_PORTS": "${sourceDir}/ports"
      },
      "cacheVariables": {
        "CMAKE_OSX_SYSROOT": "macosx",
        "CMAKE_IGNORE_PREFIX_PATH": "/usr/local"
      }
    },
    {
      "name": "macos-base",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "ORKIGE_BUILD_ENGINE": "ON",
        "ORKIGE_BUILD_TOOLS": "ON",
        "ORKIGE_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "macos-debug",
      "displayName": "macOS Debug (Ogre-Next - the default backend)",
      "inherits": "macos-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ORKIGE_RENDER_BACKEND": "next",
        "VCPKG_MANIFEST_FEATURES": "render-next"
      }
    },
    {
      "name": "macos-debug-tsan",
      "displayName": "macOS Debug (Ogre-Next, ThreadSanitizer - local repro)",
      "inherits": "macos-debug",
      "cacheVariables": {
        "ORKIGE_TSAN": "ON"
      }
    },
    {
      "name": "macos-release",
      "displayName": "macOS Release (Ogre-Next - the default backend)",
      "inherits": "macos-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ORKIGE_RENDER_BACKEND": "next",
        "VCPKG_MANIFEST_FEATURES": "render-next"
      }
    },
    {
      "name": "macos-debug-classic",
      "displayName": "macOS Debug (classic OGRE - the compatibility flavor)",
      "inherits": "macos-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ORKIGE_RENDER_BACKEND": "classic"
      }
    },
    {
      "name": "macos-release-classic",
      "displayName": "macOS Release (classic OGRE - exports package from this tree)",
      "inherits": "macos-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ORKIGE_RENDER_BACKEND": "classic"
      }
    },
    {
      "name": "macos-debug-noscript",
      "displayName": "macOS Debug (classic, ORKIGE_SCRIPTING=OFF - the seam-enforcement compile check)",
      "inherits": "macos-debug-classic",
      "cacheVariables": {
        "ORKIGE_SCRIPTING": "OFF"
      }
    },
    {
      "name": "linux-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "environment": {
        "VCPKG_ROOT": "$penv{HOME}/Development/vcpkg",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/triplets",
        "VCPKG_OVERLAY_PORTS": "${sourceDir}/ports"
      },
      "cacheVariables": {
        "ORKIGE_BUILD_ENGINE": "ON",
        "ORKIGE_BUILD_TOOLS": "ON",
        "ORKIGE_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "linux-debug-classic",
      "displayName": "Linux Debug (classic OGRE / GL3Plus - the CI flavor)",
      "inherits": "linux-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ORKIGE_RENDER_BACKEND": "classic"
      }
    },
    {
      "name": "linux-debug-next",
      "displayName": "Linux Debug (Ogre-Next / Vulkan - the default CI test flavor)",
      "inherits": "linux-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ORKIGE_RENDER_BACKEND": "next",
        "VCPKG_MANIFEST_FEATURES": "render-next"
      }
    },
    {
      "name": "linux-debug-noscript",
      "displayName": "Linux Debug (Ogre-Next, ORKIGE_SCRIPTING=OFF - the seam-enforcement CI leg)",
      "inherits": "linux-debug-next",
      "cacheVariables": {
        "ORKIGE_SCRIPTING": "OFF"
      }
    },
    {
      "name": "linux-debug-sanitize",
      "displayName": "Linux Debug (Ogre-Next, ASan + UBSan - CI only)",
      "inherits": "linux-debug-next",
      "cacheVariables": {
        "ORKIGE_ENABLE_SANITIZERS": "ON"
      }
    },
    {
      "name": "linux-debug-tsan",
      "displayName": "Linux Debug (Ogre-Next, ThreadSanitizer - CI only)",
      "inherits": "linux-debug-next",
      "cacheVariables": {
        "ORKIGE_TSAN": "ON"
      }
    },
    {
      "name": "windows-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "environment": {
        "VCPKG_ROOT": "$penv{USERPROFILE}/Development/vcpkg",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/triplets",
        "VCPKG_OVERLAY_PORTS": "${sourceDir}/ports"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-static-md",
        "ORKIGE_BUILD_ENGINE": "ON",
        "ORKIGE_BUILD_TOOLS": "ON",
        "ORKIGE_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "windows-debug",
      "displayName": "Windows Debug (Ogre-Next / Vulkan - the default backend)",
      "inherits": "windows-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ORKIGE_RENDER_BACKEND": "next",
        "VCPKG_MANIFEST_FEATURES": "render-next"
      }
    },
    {
      "name": "windows-debug-classic",
      "displayName": "Windows Debug (classic OGRE - the compatibility flavor)",
      "inherits": "windows-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ORKIGE_RENDER_BACKEND": "classic"
      }
    },
    {
      "name": "ios-simulator-debug",
      "displayName": "iOS Simulator Debug (arm64, Ogre-Next/Metal - the default backend)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_OSX_SYSROOT": "iphonesimulator",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "14.0",
        "VCPKG_TARGET_TRIPLET": "arm64-ios-simulator",
        "ORKIGE_RENDER_BACKEND": "next",
        "VCPKG_MANIFEST_FEATURES": "render-next",
        "ORKIGE_BUILD_ENGINE": "ON",
        "ORKIGE_BUILD_TOOLS": "ON",
        "ORKIGE_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "android-debug",
      "displayName": "Android Debug (arm64-v8a, API 28+, Ogre-Next/Vulkan - the default backend)",
      "inherits": "base",
      "environment": {
        "ANDROID_NDK_HOME": "$penv{HOME}/Library/Android/sdk/ndk/27.2.12479018"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_OSX_SYSROOT": null,
        "VCPKG_TARGET_TRIPLET": "arm64-android",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "$env{ANDROID_NDK_HOME}/build/cmake/android.toolchain.cmake",
        "ANDROID_ABI": "arm64-v8a",
        "ANDROID_PLATFORM": "android-28",
        "ORKIGE_RENDER_BACKEND": "next",
        "VCPKG_MANIFEST_FEATURES": "render-next",
        "ORKIGE_BUILD_ENGINE": "ON",
        "ORKIGE_BUILD_TOOLS": "ON",
        "ORKIGE_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "android-emulator-debug-ci",
      "displayName": "Android Emulator Debug (x86_64, Ogre-Next/Vulkan - CI only)",
      "inherits": "android-debug",
      "environment": {
        "ANDROID_NDK_HOME": "$penv{ANDROID_NDK_HOME}"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-android",
        "ANDROID_ABI": "x86_64"
      }
    },
    {
      "name": "android-emulator-debug-ci-classic",
      "displayName": "Android Emulator Debug (x86_64, classic OGRE/GLES2 - CI only)",
      "inherits": "android-debug-classic",
      "environment": {
        "ANDROID_NDK_HOME": "$penv{ANDROID_NDK_HOME}"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-android",
        "ANDROID_ABI": "x86_64"
      }
    },
    {
      "name": "android-release",
      "displayName": "Android Release (arm64-v8a, API 28+, Ogre-Next/Vulkan - optimized libmain.so for a store App Bundle)",
      "inherits": "base",
      "environment": {
        "ANDROID_NDK_HOME": "$penv{HOME}/Library/Android/sdk/ndk/27.2.12479018"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_OSX_SYSROOT": null,
        "VCPKG_TARGET_TRIPLET": "arm64-android",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "$env{ANDROID_NDK_HOME}/build/cmake/android.toolchain.cmake",
        "ANDROID_ABI": "arm64-v8a",
        "ANDROID_PLATFORM": "android-28",
        "ORKIGE_RENDER_BACKEND": "next",
        "VCPKG_MANIFEST_FEATURES": "render-next",
        "ORKIGE_BUILD_ENGINE": "ON",
        "ORKIGE_BUILD_TOOLS": "ON",
        "ORKIGE_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "ios-simulator-debug-classic",
      "displayName": "iOS Simulator Debug (arm64, classic OGRE/GLES2 - the compatibility flavor)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_OSX_SYSROOT": "iphonesimulator",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "14.0",
        "VCPKG_TARGET_TRIPLET": "arm64-ios-simulator",
        "ORKIGE_RENDER_BACKEND": "classic",
        "ORKIGE_BUILD_ENGINE": "ON",
        "ORKIGE_BUILD_TOOLS": "ON",
        "ORKIGE_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "android-debug-classic",
      "displayName": "Android Debug (arm64-v8a, API 28+, classic OGRE/GLES2 - the compatibility flavor)",
      "inherits": "base",
      "environment": {
        "ANDROID_NDK_HOME": "$penv{HOME}/Library/Android/sdk/ndk/27.2.12479018"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_OSX_SYSROOT": null,
        "VCPKG_TARGET_TRIPLET": "arm64-android",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "$env{ANDROID_NDK_HOME}/build/cmake/android.toolchain.cmake",
        "ANDROID_ABI": "arm64-v8a",
        "ANDROID_PLATFORM": "android-28",
        "ORKIGE_RENDER_BACKEND": "classic",
        "ORKIGE_BUILD_ENGINE": "ON",
        "ORKIGE_BUILD_TOOLS": "ON",
        "ORKIGE_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "android-release-classic",
      "displayName": "Android Release (arm64-v8a, API 28+, classic OGRE/GLES2 - optimized libmain.so for a store App Bundle)",
      "inherits": "base",
      "environment": {
        "ANDROID_NDK_HOME": "$penv{HOME}/Library/Android/sdk/ndk/27.2.12479018"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_OSX_SYSROOT": null,
        "VCPKG_TARGET_TRIPLET": "arm64-android",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "$env{ANDROID_NDK_HOME}/build/cmake/android.toolchain.cmake",
        "ANDROID_ABI": "arm64-v8a",
        "ANDROID_PLATFORM": "android-28",
        "ORKIGE_RENDER_BACKEND": "classic",
        "ORKIGE_BUILD_ENGINE": "ON",
        "ORKIGE_BUILD_TOOLS": "ON",
        "ORKIGE_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "web-release",
      "displayName": "Web Release (wasm32 via Emscripten, classic OGRE/GLES2->WebGL - the browser player)",
      "inherits": "base",
      "environment": {
        "EMSDK": "$penv{HOME}/Development/emsdk"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_OSX_SYSROOT": null,
        "VCPKG_TARGET_TRIPLET": "wasm32-emscripten",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/wasm32-emscripten-toolchain.cmake",
        "CMAKE_CXX_FLAGS": "-fwasm-exceptions",
        "CMAKE_C_FLAGS": "-fwasm-exceptions",
        "CMAKE_EXE_LINKER_FLAGS": "-fwasm-exceptions",
        "VCPKG_INSTALL_OPTIONS": "--clean-buildtrees-after-build",
        "ORKIGE_RENDER_BACKEND": "classic",
        "ORKIGE_BUILD_ENGINE": "ON",
        "ORKIGE_BUILD_TOOLS": "ON",
        "ORKIGE_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "ios-device-base",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_OSX_SYSROOT": "iphoneos",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "14.0",
        "VCPKG_TARGET_TRIPLET": "arm64-ios-device",
        "ORKIGE_BUILD_ENGINE": "ON",
        "ORKIGE_BUILD_TOOLS": "ON",
        "ORKIGE_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "ios-device-debug",
      "displayName": "iOS Device Debug (arm64 iPhoneOS, Ogre-Next/Metal - the default backend)",
      "inherits": "ios-device-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ORKIGE_RENDER_BACKEND": "next",
        "VCPKG_MANIFEST_FEATURES": "render-next"
      }
    },
    {
      "name": "ios-device-release",
      "displayName": "iOS Device Release (arm64 iPhoneOS, Ogre-Next/Metal - the default backend)",
      "inherits": "ios-device-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ORKIGE_RENDER_BACKEND": "next",
        "VCPKG_MANIFEST_FEATURES": "render-next"
      }
    },
    {
      "name": "ios-device-debug-classic",
      "displayName": "iOS Device Debug (arm64 iPhoneOS, classic OGRE/GLES2 - the compatibility flavor)",
      "inherits": "ios-device-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "ORKIGE_RENDER_BACKEND": "classic"
      }
    },
    {
      "name": "ios-device-release-classic",
      "displayName": "iOS Device Release (arm64 iPhoneOS, classic OGRE/GLES2 - the compatibility flavor)",
      "inherits": "ios-device-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ORKIGE_RENDER_BACKEND": "classic"
      }
    }
  ],
  "buildPresets": [
    {
