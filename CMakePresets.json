  "testPresets": [
    {
      "name": "unit",
      "displayName": "Unit tests (headless, fast; the default next-flavor tree)",
      "configurePreset": "macos-debug",
      "filter": {
        "include": {
          "label": "unit"
        }
      },
      "execution": {
        "jobs": 10
      },
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "unit-macos-tsan",
      "displayName": "Local macOS ThreadSanitizer: headless unit tests (Jolt worker-thread repro; sibling of unit-linux-tsan)",
      "configurePreset": "macos-debug-tsan",
      "filter": {
        "include": {
          "label": "unit"
        }
      },
      "execution": {
        "jobs": 1
      },
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "desktop",
      "displayName": "Default (Ogre-Next) suite: unit + desktop integration (no simulator/emulator boots)",
      "configurePreset": "macos-debug",
      "filter": {
        "exclude": {
          "label": "device"
        }
      },
      "execution": {
        "jobs": 6
      },
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "desktop-classic",
      "displayName": "Classic-flavor suite: unit + desktop integration incl. exports/Vulkan/native-module tests (no simulator/emulator boots)",
      "configurePreset": "macos-debug-classic",
      "filter": {
        "exclude": {
          "label": "device"
        }
      },
      "execution": {
        "jobs": 6
      },
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "all",
      "displayName": "Full classic-tree suite incl. device tests (the simulator/emulator/export flows are classic-flavored)",
      "configurePreset": "macos-debug-classic",
      "execution": {
        "jobs": 6
      },
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "unit-noscript",
      "displayName": "Unit tests on the ORKIGE_SCRIPTING=OFF tree (script-seam enforcement)",
      "configurePreset": "macos-debug-noscript",
      "filter": {
        "include": {
          "label": "unit"
        }
      },
      "execution": {
        "jobs": 10
      },
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "web-unit",
      "displayName": "Web unit tests (the Catch2 core suite as wasm, hosted by node)",
      "configurePreset": "web-release",
      "filter": {
        "include": {
          "label": "unit"
        }
      },
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "web",
      "displayName": "Web suite: node-hosted units + export structure/boot (boot SKIPs without a headless browser)",
      "configurePreset": "web-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "unit-macos-ci",
      "displayName": "macOS CI: headless unit tests on the default (next) tree",
      "configurePreset": "macos-debug",
      "filter": {
        "include": {
          "label": "unit"
        }
      },
      "execution": {
        "jobs": 3
      },
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "desktop-macos-ci",
      "displayName": "macOS CI: complete Ogre-Next desktop suite (device tests excluded)",
      "configurePreset": "macos-debug",
      "filter": {
        "exclude": {
          "label": "device"
        }
      },
      "execution": {
        "jobs": 3
      },
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "unit-macos-classic-ci",
      "displayName": "macOS CI: headless unit tests on the classic tree",
      "configurePreset": "macos-debug-classic",
      "filter": {
        "include": {
          "label": "unit"
        }
      },
      "execution": {
        "jobs": 3
      },
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "desktop-macos-classic-ci",
      "displayName": "macOS CI: complete classic desktop suite (device tests excluded)",
      "configurePreset": "macos-debug-classic",
      "filter": {
        "exclude": {
          "label": "device",
          "name": "^(export_macos_lua|export_macos_native)$"
        }
      },
      "execution": {
        "jobs": 1
      },
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "device-macos-ios-ci",
      "displayName": "iOS Simulator CI: export + play + cold-boot + safe-area tests",
      "configurePreset": "macos-debug",
      "environment": {
        "ORKIGE_REQUIRE_DEVICE_TEST_TARGET": "1"
      },
      "filter": {
        "include": {
          "name": "^(export_ios_simulator|editor_play_simulator|editor_play_simulator_boot|player_safearea_device)$"
        }
      },
      "execution": {
        "jobs": 1
      },
      "output": {
        "outputOnFailure": true
      }
    },
