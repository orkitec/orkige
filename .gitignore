build/
# a manual local /api/ render (Docs/api/Doxyfile) writes here
Docs/api/build/
.DS_Store
*.log
# native project modules build in-place, per render flavor (compile-on-Play:
# native/build-<flavor>; the exporter: native/build-export-<flavor>)
projects/*/native/build*/
# project export outputs (Util/orkige_export.py): packaged artifacts
projects/*/builds/
__pycache__/
.claude/

# runtime crash trail written to the cwd by players/tests run from the repo root
breadcrumbs.jsonl
breadcrumbs.prev.jsonl
*.oscene.autosave

# per-project editor-side state (script breakpoints - ScriptBreakpointStore)
.orkige/
