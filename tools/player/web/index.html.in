<!DOCTYPE html>
<!--
  Orkige web player shell - written by Util/orkige_export.py --platform web.
  The page hosts the wasm player: the .data image (engine media + project
  payload + the orkige_project.txt marker, packed by Emscripten's
  file_packager) mounts into the module's filesystem before main() runs, so
  the player boots its bundled project exactly like the other exported apps.

  Automation hooks (the same environment probes the native player reads via
  getenv - Emscripten's ENV map feeds them): query parameters of the form
  ?env.NAME=VALUE become environment variables, e.g. ?env.ORKIGE_DEMO_FRAMES=120
  frame-limits the run. The runtime's exit code lands in document.title as
  "ORKIGE_EXIT_<code>" so a headless browser session can assert the outcome.
-->
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
<title>@TITLE@</title>
<link rel="icon" type="image/png" href="icon.png">
<style>
  html, body {
    margin: 0; padding: 0; width: 100%; height: 100%;
    background: @BACKGROUND@; overflow: hidden;
  }
  .stage {
    display: flex; align-items: center; justify-content: center;
    width: 100%; height: 100%;
  }
  canvas.orkige {
    display: block; border: 0; outline: none;
    background: @BACKGROUND@;
    /* Fill the container - a small iframe embed as much as a full browser
       tab. The render window is sized to this same container (see the
       ORKIGE_WINDOW_SIZE preRun below), so the backing store MATCHES the
       display 1:1 and there is no CSS scaling: the HUD and on-screen buttons
       fit the frame AND hit-test correctly, because pointer coordinates map
       straight through. A fixed-size canvas CSS-scaled into a smaller
       container is what cropped the edges (HUD title, results buttons) out of
       view and left them unclickable. */
    width: 100%; height: 100%;
  }
  .status {
    position: absolute; left: 0; right: 0; bottom: 12px;
    color: #8a93a5; font: 13px/1.4 -apple-system, system-ui, sans-serif;
    text-align: center; pointer-events: none;
  }
  .status.error {
    /* readable on ANY per-project launch background: own dark backdrop */
    color: #ffd9d5; background: rgba(20, 12, 10, 0.88);
    font-size: 15px; bottom: 50%;
    left: 50%; right: auto; transform: translateX(-50%);
    max-width: 80%; padding: 14px 22px; border-radius: 8px;
  }
</style>
</head>
<body>
<div class="stage">
  <canvas class="orkige" id="canvas" width="1280" height="720"
          oncontextmenu="event.preventDefault()" tabindex="-1"></canvas>
</div>
<div class="status" id="status">loading&hellip;</div>
<script>
  var statusElement = document.getElementById('status');
  // a failed boot must SAY SO on the page - the game files come from the
  // editor's Play-in-Browser server (or any static host), and a vanished
  // server otherwise leaves a silent launch-background page
  function showError(text) {
    statusElement.textContent = text;
    statusElement.className = 'status error';
    document.title = 'ORKIGE_ERROR';
  }
  function scriptFailed() {
    showError('could not load the game files - if this tab came from ' +
      'Play in Browser, the serving editor may have stopped; play again ' +
      'from the editor');
  }
  window.addEventListener('error', function (event) {
    if (event.message) {
      showError('error: ' + event.message);
    }
  });
  var Module = {
    canvas: document.getElementById('canvas'),
    // query parameters ?env.NAME=VALUE -> the module's environment (read
    // back by getenv in the player: demo frame caps, cvar seeds, ...)
    preRun: [function () {
      var params = new URLSearchParams(window.location.search);
      params.forEach(function (value, key) {
        if (key.indexOf('env.') === 0) {
          ENV[key.substring(4)] = value;
        }
      });
      // Size the render window to the canvas' container (in CSS pixels) so the
      // backing store matches the DISPLAY - the responsive-canvas fix. The
      // player reads ORKIGE_WINDOW_SIZE and creates its SDL window at exactly
      // this size, so a small iframe embed renders (and hit-tests) at its own
      // resolution instead of a fixed 1280x720 that overflows and crops. A
      // caller-supplied ?env.ORKIGE_WINDOW_SIZE wins (tests pin a size).
      if (!ENV.ORKIGE_WINDOW_SIZE) {
        var w = Math.max(1, Math.round(window.innerWidth || 1280));
        var h = Math.max(1, Math.round(window.innerHeight || 720));
        ENV.ORKIGE_WINDOW_SIZE = w + 'x' + h;
      }
    }],
    print: function (text) {
      console.log(text);
    },
    printErr: function (text) {
      console.error(text);
    },
    setStatus: function (text) {
      statusElement.textContent = text || '';
    },
    onRuntimeInitialized: function () {
      statusElement.textContent = '';
    },
    onExit: function (code) {
      document.title = 'ORKIGE_EXIT_' + code;
      statusElement.textContent = 'exited (' + code + ')';
    },
    onAbort: function (what) {
      showError('the game aborted: ' + what);
    }
  };
</script>
<script src="@DATA_LOADER@" onerror="scriptFailed()"></script>
<script src="@PLAYER_JS@" onerror="scriptFailed()"></script>
</body>
</html>
