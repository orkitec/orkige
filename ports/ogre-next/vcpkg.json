{
  "name": "ogre-next",
  "version-date": "2026-07-11",
  "description": "OGRE-Next (ogre v2.x line) - scene-oriented, flexible 3D engine with AZDO renderer, Hlms material system and first-class Metal support",
  "homepage": "https://github.com/OGRECave/ogre-next",
  "license": "MIT",
  "supports": "(osx & arm64) | (linux & x64) | (windows & x64 & !uwp) | (ios & arm64) | (android & (arm64 | x64))",
  "dependencies": [
    {
      "name": "freeimage",
      "platform": "!ios & !android"
    },
    "rapidjson",
    "zlib",
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "glslang",
      "platform": "linux | android | windows"
    },
    {
      "name": "vulkan-headers",
      "platform": "linux | windows"
    },
    {
      "name": "vulkan-loader",
      "platform": "linux | windows"
    }
  ]
}
