diff --git a/CMake/Packages/FindVulkan.cmake b/CMake/Packages/FindVulkan.cmake
index ce28772..efe3ee2 100644
--- a/CMake/Packages/FindVulkan.cmake
+++ b/CMake/Packages/FindVulkan.cmake
@@ -152,13 +152,26 @@ else()
 		)
 endif()
 
-set(Vulkan_LIBRARIES ${Vulkan_LIBRARY} optimized ${Vulkan_SHADERC_LIB_REL} debug ${Vulkan_SHADERC_LIB_DBG})
-set(Vulkan_INCLUDE_DIRS ${Vulkan_INCLUDE_DIR} ${Vulkan_SHADERC_INCLUDE_DIR})
+# The Vulkan render system compiles GLSL to SPIR-V through glslang and never
+# links shaderc_combined; append the shaderc library/include entries only when
+# they were actually found so an absent shaderc leaves neither a dangling
+# optimized/debug keyword in Vulkan_LIBRARIES (that keyword would reach
+# target_link_libraries and hard-error) nor a NOTFOUND include dir in
+# Vulkan_INCLUDE_DIRS (a relative-path generate error).
+set(Vulkan_LIBRARIES ${Vulkan_LIBRARY})
+if(Vulkan_SHADERC_LIB_REL AND Vulkan_SHADERC_LIB_DBG)
+	list(APPEND Vulkan_LIBRARIES optimized ${Vulkan_SHADERC_LIB_REL} debug ${Vulkan_SHADERC_LIB_DBG})
+endif()
+set(Vulkan_INCLUDE_DIRS ${Vulkan_INCLUDE_DIR})
+if(Vulkan_SHADERC_INCLUDE_DIR)
+	list(APPEND Vulkan_INCLUDE_DIRS ${Vulkan_SHADERC_INCLUDE_DIR})
+endif()
 
 include(FindPackageHandleStandardArgs)
+# shaderc is not required (see above): the loader and headers are sufficient.
 find_package_handle_standard_args(Vulkan
   DEFAULT_MSG
-  Vulkan_LIBRARY Vulkan_SHADERC_LIB_REL Vulkan_SHADERC_LIB_DBG Vulkan_INCLUDE_DIR)
+  Vulkan_LIBRARY Vulkan_INCLUDE_DIR)
 
 mark_as_advanced(Vulkan_INCLUDE_DIR Vulkan_LIBRARY Vulkan_SHADERC_INCLUDE_DIR Vulkan_SHADERC_LIB_REL Vulkan_SHADERC_LIB_DBG Vulkan_GLSLC_EXECUTABLE)
 
